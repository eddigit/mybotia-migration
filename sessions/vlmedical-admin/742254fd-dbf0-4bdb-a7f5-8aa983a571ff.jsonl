ont-size: 11pt;\n        }\n        .section {\n            margin: 20px 0;\n        }\n        .section h2 {\n            color: #003366;\n            font-size: 12pt;\n            border-bottom: 2px solid #003366;\n            padding-bottom: 4px;\n            margin-bottom: 10px;\n        }\n        .conditions {\n            background-color: #fff3cd;\n            border-left: 4px solid #ff9800;\n            padding: 12px;\n            margin: 15px 0;\n            font-size: 9.5pt;\n        }\n        .conditions strong {\n            color: #d32f2f;\n        }\n        .footer {\n            margin-top: 30px;\n            text-align: center;\n            font-size: 8.5pt;\n            color: #666;\n            border-top: 2px solid #003366;\n            padding-top: 15px;\n        }\n        .signature-box {\n            margin: 25px 0;\n            padding: 15px;\n            border: 2px solid #003366;\n            background-color: #f9f9f9;\n        }\n        .signature-line {\n            border-bottom: 1px solid #333;\n            display: inline-block;\n            min-width: 200px;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"header\">\n        <h1>PROFORMA INVOICE</h1>\n        <p style=\"font-size: 11pt; margin: 5px 0;\">Export - Emilabo Nitrile Gloves</p>\n        <p style=\"font-size: 10pt; margin: 5px 0;\"><strong>Date:</strong> March 27, 2026 | <strong>Proforma N°:</strong> 20260304</p>\n    </div>\n\n    <div class=\"info-grid\">\n        <div class=\"info-row\">\n            <div class=\"info-cell\">\n                <div class=\"box\">\n                    <strong>SELLER:</strong><br>\n                    VL MEDICAL SAS<br>\n                    190 Rue Topaze<br>\n                    13510 Éguilles, FRANCE<br>\n                    SIRET: 853 225 100 00025<br>\n                    VAT: FR 27853225100<br>\n                    <strong>Contact:</strong> Jean-Luc AUBAGNAC<br>\n                    Phone: +33 6 18 24 40 13<br>\n       